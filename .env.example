# =============================================================
# Supabase — required
# =============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================
# App
# =============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================
# SendGrid — email notifications (Phase 2)
# =============================================================
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@example.com
SENDGRID_FROM_NAME=Lead Gen
SENDGRID_LEAD_TEMPLATE_ID=

# =============================================================
# Twilio — SMS notifications (Phase 2)
# =============================================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# =============================================================
# Notifications — where to send lead alerts (Phase 2)
# =============================================================
NOTIFY_EMAIL=
NOTIFY_PHONE=

# =============================================================
# Analytics — GA4 + Google Ads (Phase 2)
# =============================================================
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
NEXT_PUBLIC_GADS_ID=
GA4_MEASUREMENT_ID=
GA4_API_SECRET=

# =============================================================
# Vercel KV — rate limiting + idempotency (Phase 2)
# Set automatically by Vercel when you add the KV integration.
# =============================================================
KV_REST_API_URL=
KV_REST_API_TOKEN=

# =============================================================
# Google Ads — reporting (Phase 6)
# =============================================================
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# =============================================================
# Sentry — error tracking (Phase 7)
# =============================================================
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# =============================================================
# Call tracking (Mediahawk) — Phase 2
# =============================================================
MEDIAHAWK_ACCOUNT_ID=
MEDIAHAWK_API_KEY=
