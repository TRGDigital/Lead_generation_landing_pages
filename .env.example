# =============================================================
# Supabase — required
# =============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================
# App
# =============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================
# SendGrid — required from Phase 2
# =============================================================
SENDGRID_API_KEY=

# =============================================================
# Twilio — required from Phase 2
# =============================================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# =============================================================
# Google Ads — required from Phase 6
# =============================================================
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# =============================================================
# Sentry — required from Phase 7
# =============================================================
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# =============================================================
# Analytics — required from Phase 5
# =============================================================
NEXT_PUBLIC_GA4_MEASUREMENT_ID=

# =============================================================
# Call tracking (Mediahawk) — required from Phase 2
# =============================================================
MEDIAHAWK_ACCOUNT_ID=
MEDIAHAWK_API_KEY=
