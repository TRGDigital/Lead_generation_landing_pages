{
  "extends": "@repo/config/tsconfig.base.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"],
      "@db/*": ["../../packages/db/src/*"],
      "@ui/*": ["../../packages/ui/src/*"],
      "@lib/*": ["../../packages/lib/src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
